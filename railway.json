{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --workspace=apps/landing && npm run build --workspace=apps/landing"
  },
  "deploy": {
    "startCommand": "cd apps/landing && npx vite preview --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "ON_FAILURE"
  }
}
