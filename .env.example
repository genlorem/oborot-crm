# =============================================================================
# OborotCRM — monorepo env reference
# =============================================================================
# Copy this file to .env.local at the root (or per-app) and fill in values.
# DO NOT commit .env* (excluded by .gitignore).
#
# Per-app .env.example files stay in apps/landing/.env.example and
# apps/app/.env.example for per-app contributors; this root file is the
# union documentation.
# =============================================================================

# ---- apps/landing (Vite) -------------------------------------------------
# Google Apps Script web app URL (Google Sheets receiver)
VITE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Telegram notifications (lead capture)
VITE_TG_BOT_TOKEN=1234567890:ABCdef...
VITE_TG_CHAT_ID=123456789

# Sentry (client-side)
VITE_SENTRY_DSN=https://<key>@oXXX.ingest.sentry.io/<project>
# Optional — set in CI to tag releases
VITE_SENTRY_RELEASE=

# ---- apps/app (Next.js) --------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Sentry (both server + client)
NEXT_PUBLIC_SENTRY_DSN=https://<key>@oXXX.ingest.sentry.io/<project>
# Server-only — only used in CI / build (for source-maps upload)
SENTRY_AUTH_TOKEN=
